function greet(name) {
    return "Hello, " + name + "!";
}
console.log(typeof greet); // "function"

const greetExpression = function(name) {
    return "Hello, " + name + "!";
};
console.log(typeof greetExpression); // "function"

const greetArrow = (name) => {
    return "Hello, " + name + "!";
};
console.log(typeof greetArrow); // "function"





